<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMMAR — Brand Identity System</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --gold: #C9A84C;
  --gold-light: #E2C97E;
  --gold-dark: #8B6914;
  --ink: #0C0B09;
  --ink-2: #141210;
  --ink-3: #1E1C18;
  --cream: #F4EFE4;
  --cream-dim: #C8BFA8;
  --muted: #6B6456;
  --faint: #2A2720;
  --ease: cubic-bezier(0.4, 0, 0.2, 1);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Jost', sans-serif;
  background: var(--ink);
  color: var(--cream);
  overflow-x: hidden;
  line-height: 1.6;
}

/* ═══════════════════════════════════
   SECTION WRAPPER
═══════════════════════════════════ */
.section { padding: 100px 48px; max-width: 1100px; margin: 0 auto; }
.section-sm { padding: 70px 48px; max-width: 1100px; margin: 0 auto; }
.divider { width: 100%; height: 1px; background: var(--faint); }

/* ═══════════════════════════════════
   NAV
═══════════════════════════════════ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 48px;
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(12,11,9,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--faint);
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 500;
  letter-spacing: 6px; text-transform: uppercase;
  color: var(--gold);
}
.nav-links { display: flex; gap: 32px; }
.nav-links a {
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); text-decoration: none; font-weight: 300;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--cream); }

/* ═══════════════════════════════════
   HERO
═══════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
  padding: 120px 48px 80px;
}

.hero-bg {
  position: absolute; inset: 0;
  background: 
    radial-gradient(ellipse 70% 50% at 50% 40%, rgba(201,168,76,0.08), transparent 65%),
    radial-gradient(ellipse 40% 60% at 20% 80%, rgba(201,168,76,0.04), transparent),
    radial-gradient(ellipse 40% 60% at 80% 20%, rgba(201,168,76,0.04), transparent);
}

/* Geometric background ornament */
.hero-ornament {
  position: absolute;
  width: 600px; height: 600px;
  border: 1px solid rgba(201,168,76,0.06);
  border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation: rotate-slow 60s linear infinite;
}
.hero-ornament::before {
  content: '';
  position: absolute; inset: 30px;
  border: 1px solid rgba(201,168,76,0.04);
  border-radius: 50%;
}
.hero-ornament::after {
  content: '';
  position: absolute; inset: 80px;
  border: 1px solid rgba(201,168,76,0.03);
  border-radius: 50%;
}
@keyframes rotate-slow { to { transform: translate(-50%, -50%) rotate(360deg); } }

.hero-eyebrow {
  font-size: 10px; letter-spacing: 5px; text-transform: uppercase;
  color: var(--gold); font-weight: 300;
  margin-bottom: 32px;
  position: relative;
  display: flex; align-items: center; gap: 16px;
}
.hero-eyebrow::before, .hero-eyebrow::after {
  content: ''; width: 40px; height: 1px; background: var(--gold-dark);
}

.hero-wordmark {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(72px, 14vw, 160px);
  font-weight: 300;
  letter-spacing: 0.25em;
  line-height: 0.9;
  color: var(--cream);
  position: relative;
  margin-bottom: 24px;
}
.hero-wordmark span {
  display: inline-block;
  animation: fadeUp 0.8s var(--ease) both;
}
.hero-wordmark span:nth-child(1) { animation-delay: 0.1s; }
.hero-wordmark span:nth-child(2) { animation-delay: 0.2s; }
.hero-wordmark span:nth-child(3) { animation-delay: 0.3s; }
.hero-wordmark span:nth-child(4) { animation-delay: 0.4s; }
.hero-wordmark span:nth-child(5) { animation-delay: 0.5s; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px; font-weight: 300;
  color: var(--gold); opacity: 0.7;
  margin-bottom: 20px;
  direction: rtl;
}

.hero-meaning {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(16px, 2.5vw, 22px);
  font-weight: 300; font-style: italic;
  color: var(--cream-dim);
  margin-bottom: 48px;
  max-width: 480px;
}

.hero-tagline-options {
  display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
  margin-bottom: 60px;
}
.tagline-pill {
  padding: 10px 22px;
  border: 1px solid var(--faint);
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); font-weight: 300;
  cursor: pointer;
  transition: all 0.3s var(--ease);
}
.tagline-pill:hover, .tagline-pill.active {
  border-color: var(--gold);
  color: var(--gold);
  background: rgba(201,168,76,0.05);
}
.tagline-display {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(14px, 2vw, 18px);
  font-style: italic; color: var(--cream-dim);
  min-height: 28px;
  transition: opacity 0.3s;
}

/* ═══════════════════════════════════
   NAME ANALYSIS
═══════════════════════════════════ */
.name-section { background: var(--ink-2); }
.name-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-top: 48px;
}
.name-card {
  padding: 40px;
  background: var(--ink-3);
  position: relative;
  overflow: hidden;
}
.name-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
}
.name-card.yours::before { background: linear-gradient(90deg, transparent, var(--gold), transparent); }
.name-card.alt::before { background: linear-gradient(90deg, transparent, var(--muted), transparent); }
.name-card.alt.strong::before { background: linear-gradient(90deg, transparent, #8896d8, transparent); }

.nc-label {
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 20px; display: block;
}
.nc-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px; font-weight: 400;
  margin-bottom: 6px; line-height: 1;
}
.nc-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; color: var(--gold); opacity: 0.7;
  margin-bottom: 16px; direction: rtl;
}
.nc-meaning {
  font-size: 13px; font-weight: 300; color: var(--cream-dim);
  margin-bottom: 20px; line-height: 1.7;
}
.nc-verdict {
  display: inline-block;
  padding: 5px 14px;
  font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
  font-weight: 400;
}
.verdict-yours { background: rgba(201,168,76,0.1); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }
.verdict-strong { background: rgba(136,150,216,0.1); color: #8896d8; border: 1px solid rgba(136,150,216,0.3); }
.verdict-good { background: rgba(255,255,255,0.05); color: var(--muted); border: 1px solid var(--faint); }

.trademark-note {
  margin-top: 40px;
  padding: 24px 32px;
  border: 1px solid var(--faint);
  background: rgba(201,168,76,0.03);
  display: flex; gap: 16px; align-items: flex-start;
}
.tn-icon { color: var(--gold); font-size: 18px; flex-shrink: 0; margin-top: 2px; }
.tn-text { font-size: 13px; font-weight: 300; color: var(--muted); line-height: 1.7; }
.tn-text strong { color: var(--cream-dim); font-weight: 400; }

/* ═══════════════════════════════════
   LOGO CONCEPTS
═══════════════════════════════════ */
.logos-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 300; margin-bottom: 12px;
}
.logos-sub {
  font-size: 13px; font-weight: 300; color: var(--muted);
  letter-spacing: 1px; margin-bottom: 60px;
}

.logo-concepts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}

.logo-concept {
  background: var(--ink-3);
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.3s var(--ease);
}
.logo-concept:hover { transform: translateY(-3px); }

.logo-preview {
  height: 260px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Logo 1: Pure wordmark */
.logo-1-preview {
  background: var(--ink);
}
.logo-1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 52px; font-weight: 300;
  letter-spacing: 0.35em;
  color: var(--cream);
  text-transform: uppercase;
  position: relative;
}
.logo-1::after {
  content: '';
  position: absolute;
  bottom: -8px; left: 0; right: 0;
  height: 1px;
  background: var(--gold);
}

/* Logo 2: Emblem with geometric ornament */
.logo-2-preview {
  background: var(--cream);
  flex-direction: column; gap: 10px;
}
.logo-2-emblem {
  position: relative;
  width: 80px; height: 80px;
  display: flex; align-items: center; justify-content: center;
}
.logo-2-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px; font-weight: 600;
  letter-spacing: 0.3em;
  color: var(--ink);
  text-transform: uppercase;
}
.logo-2-sub {
  font-family: 'Jost', sans-serif;
  font-size: 9px; font-weight: 300;
  letter-spacing: 4px; text-transform: uppercase;
  color: var(--ink); opacity: 0.4;
}

/* Logo 3: Arabic + Latin stacked */
.logo-3-preview {
  background: var(--ink-2);
  flex-direction: column; gap: 4px;
}
.logo-3-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px; font-weight: 300;
  color: var(--gold);
  direction: rtl; letter-spacing: 2px;
}
.logo-3-divider {
  width: 60px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.logo-3-latin {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px; font-weight: 300;
  letter-spacing: 0.5em;
  color: var(--cream);
  text-transform: uppercase;
}

.logo-info {
  padding: 24px 28px;
  border-top: 1px solid var(--faint);
}
.li-name {
  font-size: 13px; font-weight: 500; color: var(--cream);
  margin-bottom: 6px; letter-spacing: 0.5px;
}
.li-desc {
  font-size: 12px; font-weight: 300; color: var(--muted);
  line-height: 1.6;
}
.li-tag {
  display: inline-block; margin-top: 10px;
  padding: 4px 10px;
  font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
  border: 1px solid var(--faint); color: var(--muted);
}

/* ═══════════════════════════════════
   COLOR SYSTEM
═══════════════════════════════════ */
.color-section { background: var(--ink-2); }
.color-system {
  margin-top: 48px;
}
.color-role {
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 20px; display: block;
}
.color-row {
  display: flex; gap: 2px; margin-bottom: 2px;
}
.color-swatch {
  flex: 1; height: 90px;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: flex 0.4s var(--ease);
}
.color-swatch:hover { flex: 2.5; }
.color-swatch:hover .swatch-info { opacity: 1; transform: translateY(0); }
.swatch-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 10px 14px;
  background: rgba(0,0,0,0.5);
  opacity: 0; transform: translateY(4px);
  transition: all 0.3s var(--ease);
}
.swatch-name { font-size: 10px; letter-spacing: 1px; color: rgba(255,255,255,0.8); display: block; }
.swatch-hex { font-size: 10px; color: rgba(255,255,255,0.5); display: block; font-family: monospace; }

/* Primary palette */
.s-gold { background: #C9A84C; }
.s-gold-l { background: #E2C97E; }
.s-gold-d { background: #8B6914; }
.s-ink { background: #0C0B09; border: 1px solid #1e1e1e; }
.s-ink2 { background: #141210; }
.s-cream { background: #F4EFE4; }
.s-cream2 { background: #C8BFA8; }
/* Accent palette */
.s-navy { background: #12213A; }
.s-sage { background: #3D5145; }
.s-stone { background: #8C7B65; }
.s-taupe { background: #C4B49A; }

.palette-usage {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 2px; margin-top: 2px;
}
.usage-card {
  padding: 24px 28px;
  background: var(--ink-3);
}
.uc-title {
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 12px; display: block;
}
.uc-dots {
  display: flex; gap: 8px; flex-wrap: wrap;
}
.uc-dot {
  width: 20px; height: 20px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.uc-body {
  font-size: 12px; font-weight: 300; color: var(--muted);
  margin-top: 12px; line-height: 1.6;
}

/* ═══════════════════════════════════
   TYPOGRAPHY
═══════════════════════════════════ */
.type-system {
  margin-top: 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
}
.type-card {
  background: var(--ink-3);
  padding: 40px;
}
.type-label {
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 24px; display: block;
}
.type-display {
  font-family: 'Cormorant Garamond', serif;
  font-size: 52px; font-weight: 300;
  line-height: 1; color: var(--cream);
  margin-bottom: 16px;
}
.type-display-italic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px; font-weight: 300; font-style: italic;
  line-height: 1; color: var(--gold);
  margin-bottom: 16px;
}
.type-body-ex {
  font-family: 'Jost', sans-serif;
  font-size: 14px; font-weight: 300;
  color: var(--cream-dim); line-height: 1.7;
  margin-bottom: 16px;
}
.type-caps {
  font-family: 'Jost', sans-serif;
  font-size: 10px; font-weight: 400; letter-spacing: 3px;
  text-transform: uppercase; color: var(--muted);
}
.type-meta {
  font-size: 11px; color: var(--muted); margin-top: 20px;
  padding-top: 20px; border-top: 1px solid var(--faint);
  font-weight: 300;
}
.type-meta strong { color: var(--cream-dim); font-weight: 400; }

/* ═══════════════════════════════════
   BRAND IN USE — MOCKUP
═══════════════════════════════════ */
.mockup-section {}
.mockup-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
  margin-top: 48px;
}
.mockup-card {
  position: relative; overflow: hidden;
  background: var(--ink-3);
}

/* Hang tag mockup */
.hangtag {
  padding: 48px;
  display: flex; align-items: center; justify-content: center;
  min-height: 340px;
}
.hangtag-inner {
  width: 160px;
  background: var(--cream);
  padding: 28px 20px 24px;
  position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.hangtag-hole {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--ink);
  margin: 0 auto 20px;
}
.hangtag-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 400; letter-spacing: 0.4em;
  color: var(--ink); text-align: center; text-transform: uppercase;
  margin-bottom: 6px;
}
.hangtag-line { width: 40px; height: 1px; background: var(--gold); margin: 0 auto 10px; }
.hangtag-sub {
  font-size: 7px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink); opacity: 0.4; text-align: center;
}
.hangtag-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px; color: var(--gold-dark);
  text-align: center; margin-top: 14px; direction: rtl;
}

/* Label mockup */
.label-card {
  padding: 48px;
  display: flex; align-items: center; justify-content: center;
  min-height: 340px;
  background: var(--ink);
}
.woven-label {
  background: #1a1612;
  border: 1px solid #2a2520;
  padding: 18px 28px;
  position: relative;
}
.wl-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 400; letter-spacing: 0.5em;
  color: var(--gold); text-transform: uppercase;
  text-align: center; margin-bottom: 6px;
}
.wl-line { width: 100%; height: 1px; background: var(--faint); margin: 8px 0; }
.wl-sub {
  font-size: 8px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); text-align: center; font-weight: 300;
}

/* Business card mockup */
.bcard-card {
  padding: 48px;
  display: flex; align-items: center; justify-content: center;
  min-height: 340px;
}
.bcard {
  width: 280px;
  background: var(--ink);
  border: 1px solid #2a2520;
  padding: 32px 28px;
  position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6);
}
.bcard::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.bcard-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px; font-weight: 300; letter-spacing: 0.5em;
  color: var(--cream); text-transform: uppercase; margin-bottom: 4px;
}
.bcard-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px; color: var(--gold); opacity: 0.6;
  direction: rtl; margin-bottom: 24px;
}
.bcard-divider { width: 30px; height: 1px; background: var(--gold-dark); margin-bottom: 20px; }
.bcard-name { font-size: 12px; color: var(--cream); margin-bottom: 4px; font-weight: 400; }
.bcard-title { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); font-weight: 300; margin-bottom: 16px; }
.bcard-contact { font-size: 10px; color: var(--muted); font-weight: 300; line-height: 1.8; }

/* Packaging mockup */
.pkg-card {
  padding: 48px;
  display: flex; align-items: center; justify-content: center;
  min-height: 340px;
  background: #0a0905;
}
.pkg-box {
  width: 180px; height: 220px;
  background: var(--cream);
  position: relative;
  box-shadow: -12px 12px 40px rgba(0,0,0,0.8), 12px -6px 30px rgba(0,0,0,0.4);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8px;
}
.pkg-box::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--gold);
}
.pkg-brand {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 400; letter-spacing: 0.4em;
  color: var(--ink); text-transform: uppercase;
}
.pkg-line { width: 50px; height: 1px; background: var(--gold-dark); }
.pkg-arabic {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px; color: var(--gold-dark);
  direction: rtl;
}
.pkg-sub {
  font-size: 7px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--ink); opacity: 0.3;
}

.mockup-label {
  position: absolute; bottom: 16px; left: 20px;
  font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted);
}

/* ═══════════════════════════════════
   TAGLINE SECTION
═══════════════════════════════════ */
.tagline-section {
  background: var(--ink-2);
  text-align: center;
}
.taglines-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; margin-top: 48px;
}
.tg-card {
  background: var(--ink-3); padding: 36px 28px;
  position: relative;
}
.tg-number {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px; letter-spacing: 3px; color: var(--faint);
  display: block; margin-bottom: 20px;
}
.tg-line {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; font-weight: 300; font-style: italic;
  color: var(--cream); line-height: 1.3; margin-bottom: 12px;
}
.tg-sub {
  font-size: 11px; font-weight: 300; color: var(--muted); letter-spacing: 0.5px;
}
.tg-star { color: var(--gold); font-size: 10px; }

/* ═══════════════════════════════════
   FOOTER CTA
═══════════════════════════════════ */
.footer-cta {
  padding: 100px 48px;
  text-align: center;
